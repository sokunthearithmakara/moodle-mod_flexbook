{{!
    @template mod_flexbook/canvas/messagetitle

    TODO describe template messagetitle

    Example context (json):
    {
    }
}}
{{#title}}
<h5 class="modal-title text-truncate mb-0 d-flex align-items-center"
    id="modal-title-{{id}}"
    role="heading"
    aria-level="5">
    {{#logourl}}
    <img src="{{logourl}}" class="iv-mr-2 d-none d-md-inline" style="height: 35px; width: auto;" alt="" loading="lazy" onerror="this.remove(); document.getElementById('modal-icon-{{id}}').classList.remove('d-none'); document.getElementById('modal-icon-{{id}}').classList.add('d-md-inline');">
    <i class="{{icon}} iv-mr-2 d-none fs-25px"
       id="modal-icon-{{id}}"
       aria-hidden="true"></i>
    {{/logourl}}
    {{^logourl}}
    <i class="{{icon}} iv-mr-2 d-none d-md-inline fs-25px"
       aria-hidden="true"></i>
    {{/logourl}}
    <span class="text-truncate">{{{title}}}</span>
</h5>
{{/title}}
<div class="btns d-flex align-items-center">
    {{{completionbutton}}}
    {{#completionbutton}}
    {{#showdelete}}
    <button data-id="{{id}}"
            class="btn btn-flex iv-ml-2 p-0 border-0 {{^candelete}}d-none{{/candelete}}"
            id="delete-completiondata"
            type="button"
            data{{bs}}-toggle="tooltip"
            data{{bs}}-container="#wrapper"
            data{{bs}}-trigger="hover"
            aria-label="{{#str}}deletecompletion, mod_interactivevideo{{/str}}"
            title="{{#str}}deletecompletion, mod_interactivevideo{{/str}}">
        <i class="bi bi-trash3 text-danger fs-25px" aria-hidden="true"></i>
    </button>
    {{/showdelete}}
    {{/completionbutton}}
</div>
