{{!
    @template mod_flexbook/editor/bulktoolbar

    Floating bulk-action pill toolbar. Hidden off-screen by default;
    JavaScript slides it up when one or more list rows are selected.

    Example context (json):
    {}
}}
<div id="bulk-action-toolbar"
     class="position-fixed">

    <div class="d-flex align-items-center bg-dark text-white iv-rounded-pill shadow-lg py-2 px-3">

        <!-- Selection State -->
        <div class="d-flex align-items-center iv-px-3 iv-border-right iv-mr-2" style="border-color: rgba(255,255,255,0.1) !important;">
            <div class="bg-info text-dark d-flex align-items-center justify-content-center iv-rounded-circle iv-mr-2 shadow-sm"
                 style="width: 24px; height: 24px;">
                <i class="bi bi-check2"></i>
            </div>
            <span id="bulk-count" class="small iv-font-weight-bold text-uppercase" style="letter-spacing: 0.5px;"></span>
        </div>

        <!-- Action Group -->
        <div class="d-flex align-items-center iv-px-2" style="gap: 8px;">
            <button id="bulk-clone-btn"
                    class="btn btn-primary btn-sm iv-rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                    type="button"
                    title="{{#str}}clone, mod_flexbook{{/str}}"
                    data-toggle="tooltip"
                    style="width: 36px; height: 36px; padding: 0;">
                <i class="bi bi-copy"></i>
            </button>
            <button id="bulk-delete-btn"
                    class="btn btn-danger btn-sm iv-rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                    type="button"
                    title="{{#str}}delete, mod_flexbook{{/str}}"
                    data-toggle="tooltip"
                    style="width: 36px; height: 36px; padding: 0;">
                <i class="bi bi-trash3"></i>
            </button>
        </div>

        <!-- Close -->
        <div class="iv-ml-2 iv-pl-2 iv-border-left" style="border-color: rgba(255,255,255,0.1) !important;">
            <button id="bulk-dismiss-btn"
                    class="btn btn-link text-white-50 iv-p-0 d-flex align-items-center justify-content-center"
                    type="button"
                    title="{{#str}}deselectall, core{{/str}}"
                    data-toggle="tooltip"
                    style="width: 32px; height: 32px;">
                <i class="bi bi-x-lg" style="font-size: 14px;"></i>
            </button>
        </div>
    </div>
</div>
